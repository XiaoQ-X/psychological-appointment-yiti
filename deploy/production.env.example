# Copy to deploy/.env on the server and replace every CHANGE_ME value.
MYSQL_DATABASE=psych_appointment
MYSQL_USER=psych_app
MYSQL_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

DB_URL=jdbc:mysql://mysql:3306/psych_appointment?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=true&requireSSL=true&verifyServerCertificate=false
DB_USERNAME=psych_app
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379

TOKEN_SECRET=CHANGE_ME_AT_LEAST_64_RANDOM_CHARACTERS
SENSITIVE_DATA_KEY_BASE64=CHANGE_ME_32_BYTE_BASE64_KEY
CORS_ALLOWED_ORIGINS=https://psych-admin.example.edu.cn

# Bind only to loopback. Put the school's HTTPS reverse proxy/load balancer in front.
PUBLIC_BIND=127.0.0.1
PUBLIC_PORT=8088
