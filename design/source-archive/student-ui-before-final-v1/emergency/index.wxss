page {
  background: #f8f7f1;
}

.emergency-page {
  min-height: 100vh;
  padding: 30rpx 28rpx 60rpx;
  background: #f8f7f1;
  color: #1f2a2d;
}

.emergency-hero {
  position: relative;
  padding: 12rpx 4rpx 30rpx;
  border-bottom: 1rpx solid #e8c7c1;
}

.warning-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e3aaa3;
  border-radius: 50%;
  background: #fff4f1;
}

.page-kicker {
  color: #d36f62;
  font-size: 23rpx;
  font-weight: 800;
}

.emergency-hero .page-title {
  margin: 10rpx 0 0;
  color: #1f2a2d;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.22;
}

.emergency-copy {
  max-width: 640rpx;
  margin-top: 14rpx;
  color: #6d7770;
  font-size: 24rpx;
  line-height: 1.65;
}

.immediate-section,
.support-section,
.school-section,
.safety-section {
  margin-top: 30rpx;
}

.section-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  color: #1f2a2d;
  font-size: 31rpx;
  font-weight: 800;
}

.section-note {
  color: #8a948c;
  font-size: 23rpx;
}

.immediate-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.immediate-call {
  display: block;
  min-height: 262rpx;
  margin: 0;
  padding: 22rpx 20rpx;
  border-radius: 10rpx;
  text-align: left;
}

.immediate-call::after {
  border: 0;
}

.immediate-call.medical {
  border: 1rpx solid #e3aaa3;
  border-left: 5rpx solid #d36f62;
  color: #6f342f;
  background: #fff4f1;
}

.immediate-call.police {
  border: 1rpx solid #c5d4dc;
  border-left: 5rpx solid #719cb5;
  color: #2f4d5d;
  background: #f1f6f8;
}

.call-label {
  font-size: 24rpx;
  font-weight: 700;
}

.call-number {
  margin-top: 6rpx;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 1.15;
}

.call-desc {
  min-height: 72rpx;
  margin-top: 10rpx;
  color: #6d7770;
  font-size: 23rpx;
  line-height: 1.5;
}

.call-action {
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.hotline-row {
  display: block;
  min-width: 0;
  margin-top: 14rpx;
  padding: 22rpx;
  border: 1rpx solid #d8ded7;
  border-left: 5rpx solid #7b9476;
  border-radius: 10rpx;
  background: #fefdf9;
}

.hotline-number {
  color: #7b9476;
  font-size: 38rpx;
  font-weight: 800;
}

.hotline-head {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  min-width: 0;
}

.hotline-title {
  color: #1f2a2d;
  font-size: 26rpx;
  font-weight: 800;
}

.hotline-desc {
  margin-top: 12rpx;
  color: #6d7770;
  font-size: 23rpx;
  line-height: 1.5;
}

.hotline-button,
.school-call-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  min-height: 88rpx;
  flex-shrink: 0;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  color: #ffffff;
  background: #7b9476;
  font-size: 24rpx;
  font-weight: 700;
}

.hotline-button {
  width: 100%;
  min-height: 76rpx;
  margin-top: 16rpx;
}

.hotline-button::after,
.school-call-button::after {
  border: 0;
}

.hotline-note {
  margin-top: 10rpx;
  color: #7a847d;
  font-size: 22rpx;
  line-height: 1.5;
}

.school-list {
  margin-top: 14rpx;
  border-top: 1rpx solid #d8ded7;
}

.school-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 138rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #d8ded7;
}

.school-main {
  min-width: 0;
  flex: 1;
}

.school-title {
  color: #1f2a2d;
  font-size: 26rpx;
  font-weight: 800;
}

.school-desc {
  margin-top: 6rpx;
  color: #6d7770;
  font-size: 23rpx;
  line-height: 1.45;
}

.school-phone {
  margin-top: 8rpx;
  color: #61785d;
  font-size: 23rpx;
  font-weight: 700;
}

.safety-list {
  margin-top: 14rpx;
  border-top: 1rpx solid #d8ded7;
}

.safety-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #d8ded7;
}

.safety-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  flex-shrink: 0;
  border: 1rpx solid #e3aaa3;
  border-radius: 50%;
  color: #b65349;
  font-size: 22rpx;
  font-weight: 800;
}

.safety-text {
  color: #4f5b53;
  font-size: 24rpx;
  line-height: 1.55;
}

.page-note {
  margin-top: 30rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #d8ded7;
  color: #7a847d;
  font-size: 23rpx;
  line-height: 1.6;
}

@media (max-width: 360px) {
  .immediate-grid {
    grid-template-columns: 1fr;
  }

  .immediate-call {
    min-height: 220rpx;
  }

  .call-desc {
    min-height: 0;
  }

  .hotline-row {
    padding: 18rpx;
  }

  .hotline-number {
    font-size: 34rpx;
  }

}
