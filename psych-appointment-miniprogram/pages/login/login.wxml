<view class="student-login">
  <view class="login-brand">
    <text class="login-brand-name">校园节奏</text>
    <view class="login-brand-divider"></view>
    <text class="login-brand-product">心理咨询预约</text>
  </view>

  <view class="login-intro">
    <image
      class="login-intro-art"
      src="../../assets/design/carousel-exam.png"
      mode="aspectFill"
      aria-hidden="true"
    />
    <view class="login-intro-copy">
      <view class="login-kicker">本校心理咨询预约</view>
      <view class="login-title">登录学生账号</view>
      <view class="login-subtitle">使用学校统一分配的学号和初始密码，查看咨询师与可预约时间。</view>
    </view>
  </view>

  <view class="emergency-entry" bindtap="openEmergency" hover-class="entry-pressed">
    <icon type="warn" size="24" color="#e85a47" />
    <view class="emergency-copy">
      <view class="emergency-title">需要立即帮助？</view>
      <view class="emergency-text">无需登录，可直接查看紧急求助方式</view>
    </view>
    <text class="entry-action">查看</text>
  </view>

  <view class="login-form" aria-label="学生登录表单">
    <view class="field">
      <text class="field-label">学号</text>
      <view class="input-shell {{username ? 'has-value' : ''}}">
        <input
          class="login-input"
          value="{{username}}"
          placeholder="请输入学号"
          maxlength="64"
          confirm-type="next"
          bindinput="onUsernameInput"
        />
        <icon wx:if="{{username}}" type="clear" size="20" color="#748388" bindtap="clearUsername" />
      </view>
    </view>

    <view class="field">
      <view class="password-label-row">
        <text class="field-label">密码</text>
        <text class="password-toggle" bindtap="togglePasswordVisibility">{{passwordVisible ? '隐藏' : '显示'}}</text>
      </view>
      <view class="input-shell {{password ? 'has-value' : ''}}">
        <input
          class="login-input"
          value="{{password}}"
          password="{{passwordMode}}"
          placeholder="请输入密码"
          maxlength="128"
          confirm-type="go"
          bindinput="onPasswordInput"
          bindconfirm="onPasswordConfirm"
        />
      </view>
    </view>

    <button
      class="login-button {{!canSubmit || loading ? 'disabled' : ''}}"
      loading="{{loading}}"
      disabled="{{!canSubmit || loading}}"
      bindtap="submit"
    >登录</button>

    <view class="password-help">忘记密码请联系学校心理中心或辅导员处理。</view>
  </view>

  <view class="login-footer">
    <view class="footer-links">
      <view class="footer-link" bindtap="openConsent">服务须知</view>
      <view class="footer-divider"></view>
      <view class="footer-link" bindtap="openConsent">隐私说明</view>
      <view class="footer-divider"></view>
      <view class="footer-link" bindtap="openCounselorLogin">咨询师入口</view>
    </view>
    <view class="privacy-note">登录即表示你了解本校心理咨询服务的保密原则与服务边界。</view>
  </view>
</view>
