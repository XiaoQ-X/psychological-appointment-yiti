page {
  background: #f7faf9;
  background-image: none;
}

.counselor-login-page {
  min-height: 100vh;
  padding: 20rpx 32rpx 52rpx;
  color: #15262b;
  background: #f7faf9;
}

.brand-bar,
.brand-lockup,
.login-footer {
  display: flex;
  align-items: center;
}

.brand-bar {
  justify-content: space-between;
  gap: 18rpx;
  min-height: 66rpx;
  border-bottom: 4rpx solid #167a6e;
}

.brand-lockup {
  min-width: 0;
}

.brand-name {
  flex-shrink: 0;
  color: #15262b;
  font-size: 34rpx;
  font-weight: 800;
}

.brand-divider {
  width: 1rpx;
  height: 30rpx;
  margin: 0 16rpx;
  background: #b8c5c2;
}

.brand-product,
.role-mark {
  color: #52656a;
  font-size: 23rpx;
}

.role-mark {
  flex-shrink: 0;
  padding: 6rpx 10rpx;
  border: 1rpx solid #9fc8bf;
  border-radius: 4rpx;
  color: #4d8067;
  font-weight: 700;
}

.welcome-block {
  position: relative;
  height: 260rpx;
  overflow: hidden;
  padding-top: 50rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.welcome-kicker {
  color: #167a6e;
  font-size: 20rpx;
  font-weight: 700;
}

.welcome-title {
  margin-top: 10rpx;
  color: #15262b;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.2;
}

.welcome-text {
  width: 70%;
  margin-top: 12rpx;
  color: #52656a;
  font-size: 24rpx;
  line-height: 1.55;
}

.welcome-art {
  position: absolute;
  right: -26rpx;
  bottom: -12rpx;
  width: 440rpx;
  height: 146rpx;
  opacity: 0.38;
}

.login-form {
  padding: 36rpx 0 30rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.form-heading {
  color: #15262b;
  font-size: 31rpx;
  font-weight: 800;
}

.form-note {
  margin-top: 6rpx;
  color: #748388;
  font-size: 23rpx;
}

.field {
  margin-top: 26rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #26393e;
  font-size: 25rpx;
  font-weight: 700;
}

.login-input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  border: 1rpx solid #c9d8d5;
  border-radius: 8rpx;
  color: #15262b;
  background: #ffffff;
  font-size: 27rpx;
}

.input-placeholder {
  color: #9aa7a5;
}

.login-button {
  width: 100% !important;
  min-height: 88rpx;
  margin: 34rpx 0 0;
  border-radius: 8rpx;
  color: #ffffff;
  background: #167a6e;
  font-size: 28rpx;
  font-weight: 700;
}

.login-button::after {
  border: 0;
}

.login-button[disabled] {
  color: rgba(255, 255, 255, 0.76);
  background: #83aaa4;
}

.login-footer {
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 24rpx;
  font-size: 22rpx;
}

.account-note {
  color: #748388;
}

.student-link {
  flex-shrink: 0;
  color: #167a6e;
  font-weight: 700;
}
