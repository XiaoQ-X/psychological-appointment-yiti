<view class="page">
  <view class="row page-head">
    <view>
      <view class="page-title">我的咨询预约</view>
      <view class="page-subtitle">查看分配给自己的预约，进入详情后可填写咨询记录。</view>
    </view>
    <button class="ghost-button" bindtap="logout">退出</button>
  </view>

  <view class="panel counselor-card">
    <view class="row">
      <view>
        <view class="section-title">{{counselor.counselorName}}</view>
        <view class="card-meta">{{counselor.username}}</view>
      </view>
      <text class="tag">咨询师</text>
    </view>
  </view>

  <scroll-view class="filter-scroll" scroll-x>
    <view class="filter-row">
      <view
        wx:for="{{filters}}"
        wx:key="value"
        class="filter-chip {{item.activeClass}}"
        data-value="{{item.value}}"
        bindtap="changeFilter"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="empty">正在加载预约</view>

  <view wx:elif="{{appointments.length == 0}}" class="empty">
    暂无预约记录
  </view>

  <view wx:else>
    <view class="section" wx:if="{{currentAppointments.length}}">
      <view class="section-head">
        <view class="section-title">当前待处理</view>
        <view class="section-note">{{currentAppointments.length}} 条</view>
      </view>
      <view class="card-list">
        <view
          wx:for="{{currentAppointments}}"
          wx:key="appointmentId"
          class="card appointment-card current"
          data-id="{{item.appointmentId}}"
          bindtap="openDetail"
        >
          <view class="row">
            <view class="card-title">{{item.studentText}}</view>
            <text class="tag {{item.tagType}}">{{item.statusText}}</text>
          </view>
          <view class="card-meta">{{item.studentMeta}}</view>
          <view class="card-meta">{{item.timeText}}</view>
          <view class="card-meta">{{item.placeText}} · {{item.serviceTypeText}}</view>
          <view class="tag-row">
            <text class="tag {{item.riskTagType}}">{{item.riskText}}</text>
            <text wx:if="{{item.canComplete}}" class="tag">可完成记录</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{historyAppointments.length}}">
      <view class="section-head">
        <view class="section-title">历史记录</view>
        <view class="section-note">{{historyAppointments.length}} 条</view>
      </view>
      <view class="card-list">
        <view
          wx:for="{{historyAppointments}}"
          wx:key="appointmentId"
          class="card appointment-card"
          data-id="{{item.appointmentId}}"
          bindtap="openDetail"
        >
          <view class="row">
            <view class="card-title">{{item.studentText}}</view>
            <text class="tag {{item.tagType}}">{{item.statusText}}</text>
          </view>
          <view class="card-meta">{{item.studentMeta}}</view>
          <view class="card-meta">{{item.timeText}}</view>
          <view class="card-meta">{{item.placeText}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
