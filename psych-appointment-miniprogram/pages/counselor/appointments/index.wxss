page {
  background: #f7faf9;
  background-image: none;
}

.counselor-page {
  min-height: 100vh;
  padding: 20rpx 28rpx 50rpx;
  color: #15262b;
  background: #f7faf9;
}

.brand-bar,
.brand-lockup,
.workspace-head,
.summary-band,
.section-heading,
.appointment-row,
.student-line,
.tag-row {
  display: flex;
  align-items: center;
}

.brand-bar {
  justify-content: space-between;
  gap: 20rpx;
  min-height: 66rpx;
  border-bottom: 4rpx solid #167a6e;
}

.brand-lockup {
  min-width: 0;
}

.brand-name {
  flex-shrink: 0;
  color: #15262b;
  font-size: 34rpx;
  font-weight: 800;
}

.brand-divider {
  width: 1rpx;
  height: 30rpx;
  margin: 0 16rpx;
  background: #b8c5c2;
}

.brand-product,
.logout-button {
  color: #52656a;
  font-size: 23rpx;
}

.logout-button {
  width: auto;
  min-width: 88rpx;
  min-height: 56rpx;
  margin: 0;
  padding: 0 14rpx;
  border: 0;
  border-radius: 8rpx;
  background: transparent;
}

.logout-button::after {
  border: 0;
}

.workspace-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 34rpx 0 26rpx;
}

.welcome-label {
  color: #167a6e;
  font-size: 23rpx;
  font-weight: 700;
}

.workspace-title {
  margin-top: 6rpx;
  color: #15262b;
  font-size: 40rpx;
  font-weight: 800;
}

.workspace-note {
  margin-top: 8rpx;
  color: #748388;
  font-size: 23rpx;
}

.role-badge {
  flex-shrink: 0;
  margin-top: 4rpx;
  padding: 8rpx 12rpx;
  border: 1rpx solid #9fc8bf;
  border-radius: 4rpx;
  color: #4d8067;
  font-size: 21rpx;
  font-weight: 700;
}

.summary-band {
  position: relative;
  min-height: 128rpx;
  padding: 20rpx 22rpx;
  border-top: 1rpx solid #b8d5cf;
  border-bottom: 1rpx solid #b8d5cf;
  background: #edf6f4;
}

.summary-item {
  width: 142rpx;
}

.summary-number {
  color: #167a6e;
  font-size: 38rpx;
  font-weight: 800;
}

.muted-number {
  color: #52656a;
}

.summary-label,
.summary-account {
  color: #52656a;
  font-size: 21rpx;
}

.summary-label {
  margin-top: 4rpx;
}

.summary-divider {
  width: 1rpx;
  height: 58rpx;
  margin-right: 24rpx;
  background: #c9d8d5;
}

.summary-account {
  position: absolute;
  right: 20rpx;
  bottom: 18rpx;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-scroll {
  margin: 26rpx -28rpx 0;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 28rpx 8rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  min-height: 62rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  color: #52656a;
  background: #ffffff;
  font-size: 23rpx;
}

.filter-chip.active {
  border-color: #167a6e;
  color: #ffffff;
  background: #167a6e;
  font-weight: 700;
}

.appointment-section {
  margin-top: 26rpx;
}

.history-section {
  margin-top: 38rpx;
}

.section-heading {
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.section-title {
  color: #15262b;
  font-size: 30rpx;
  font-weight: 800;
}

.section-note,
.section-count {
  color: #748388;
  font-size: 22rpx;
}

.section-note {
  margin-top: 5rpx;
}

.section-count {
  flex-shrink: 0;
}

.appointment-list {
  background: #ffffff;
}

.appointment-row {
  align-items: stretch;
  gap: 18rpx;
  min-width: 0;
  padding: 24rpx 4rpx 24rpx 0;
  border-bottom: 1rpx solid #d9e2e0;
}

.appointment-row.current {
  border-left: 5rpx solid #167a6e;
  padding-left: 18rpx;
}

.row-main {
  min-width: 0;
  flex: 1;
}

.student-line {
  justify-content: space-between;
  gap: 12rpx;
}

.student-name {
  min-width: 0;
  color: #15262b;
  font-size: 30rpx;
  font-weight: 800;
}

.status-tag,
.risk-tag,
.record-ready {
  flex-shrink: 0;
  padding: 5rpx 10rpx;
  border-radius: 4rpx;
  color: #167a6e;
  background: #e1f0ec;
  font-size: 21rpx;
  font-weight: 700;
}

.status-tag.warning,
.risk-tag.warning {
  color: #9a6518;
  background: #fff4dd;
}

.status-tag.danger,
.risk-tag.danger {
  color: #b04439;
  background: #fff1ee;
}

.status-tag.neutral,
.risk-tag.neutral {
  color: #52656a;
  background: #f0f3f2;
}

.appointment-time {
  margin-top: 10rpx;
  color: #26393e;
  font-size: 26rpx;
  font-weight: 700;
}

.appointment-meta {
  margin-top: 6rpx;
  color: #748388;
  font-size: 22rpx;
  line-height: 1.45;
}

.tag-row {
  gap: 10rpx;
  margin-top: 12rpx;
}

.record-ready {
  color: #3478e5;
  background: #edf4ff;
}

.row-action {
  align-self: center;
  flex-shrink: 0;
  color: #52656a;
  font-size: 22rpx;
  font-weight: 700;
}

.empty-state {
  padding: 84rpx 30rpx;
  border-bottom: 1rpx solid #d9e2e0;
  text-align: center;
}

.empty-title {
  color: #26393e;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 10rpx;
  color: #748388;
  font-size: 23rpx;
}
