page {
  background: #f7faf9;
}

.booking-page {
  min-height: 100vh;
  padding: 24rpx 28rpx 260rpx;
  color: #15262b;
  background: #f7faf9;
}

.booking-page.with-bottom-action {
  padding-bottom: 260rpx;
}

.booking-summary {
  position: relative;
  padding: 24rpx 26rpx;
  overflow: hidden;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  background: #ffffff;
}

.summary-accent {
  position: absolute;
  top: 22rpx;
  bottom: 22rpx;
  left: 0;
  width: 4rpx;
  background: #167a6e;
}

.summary-topline,
.field-heading,
.safety-title-row,
.emergency-entry,
.consent-row,
.submit-hint {
  display: flex;
  align-items: center;
}

.summary-topline,
.safety-title-row {
  justify-content: space-between;
  gap: 20rpx;
}

.summary-counselor {
  color: #15262b;
  font-size: 31rpx;
  font-weight: 800;
}

.summary-state {
  flex-shrink: 0;
  padding: 7rpx 12rpx;
  border-radius: 6rpx;
  color: #167a6e;
  background: #eaf5f3;
  font-size: 22rpx;
}

.summary-time,
.summary-place {
  margin-top: 8rpx;
  color: #52656a;
  font-size: 25rpx;
  line-height: 1.5;
  font-variant-numeric: tabular-nums;
}

.form-section {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #d9e2e0;
}

.first-section {
  padding-top: 32rpx;
}

.field-heading {
  gap: 10rpx;
  color: #15262b;
  font-size: 29rpx;
  font-weight: 800;
}

.required-text {
  color: #e85a47;
  font-size: 22rpx;
  font-weight: 500;
}

.optional-text {
  color: #748388;
  font-size: 22rpx;
  font-weight: 400;
}

.first-visit-row {
  display: flex;
  gap: 64rpx;
  margin-top: 20rpx;
}

.radio-choice,
.risk-option {
  display: inline-flex;
  align-items: center;
  min-height: 64rpx;
  gap: 8rpx;
  color: #3f5157;
  font-size: 26rpx;
}

.issue-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.issue-choice {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  min-height: 72rpx;
  padding: 10rpx 12rpx;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  color: #3f5157;
  background: #ffffff;
  font-size: 24rpx;
}

.issue-choice.selected {
  border-color: #167a6e;
  color: #15262b;
  background: #f3faf8;
}

.issue-choice text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.textarea-shell {
  position: relative;
  margin-top: 16rpx;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  background: #ffffff;
}

.description-input {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx 20rpx 48rpx;
  color: #15262b;
  font-size: 25rpx;
  line-height: 1.65;
}

.input-counter {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  color: #748388;
  font-size: 22rpx;
  font-variant-numeric: tabular-nums;
}

.text-input {
  width: 100%;
  min-height: 92rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  color: #15262b;
  background: #ffffff;
  font-size: 25rpx;
}

.section-note {
  margin-top: 6rpx;
  color: #748388;
  font-size: 23rpx;
}

.learn-link,
.consent-link {
  color: #3478e5;
  font-size: 23rpx;
}

.risk-list {
  margin-top: 18rpx;
}

.risk-question {
  padding: 18rpx 0;
  border-top: 1rpx solid #e3e9e7;
}

.risk-label {
  color: #3f5157;
  font-size: 24rpx;
  line-height: 1.55;
}

.risk-answer {
  display: flex;
  justify-content: flex-end;
  gap: 34rpx;
  margin-top: 8rpx;
}

.risk-warning {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-left: 4rpx solid #b7791f;
  color: #7d5b20;
  background: #fff8e8;
  font-size: 23rpx;
  line-height: 1.55;
}

.emergency-entry {
  gap: 14rpx;
  min-height: 82rpx;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-left: 4rpx solid #e85a47;
  background: #fff1ee;
}

.emergency-copy {
  min-width: 0;
  flex: 1;
  color: #6f3f39;
  font-size: 24rpx;
  line-height: 1.45;
}

.entry-action {
  flex-shrink: 0;
  color: #c9473d;
  font-size: 23rpx;
  font-weight: 700;
}

.consent-row {
  gap: 14rpx;
  min-height: 94rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #d9e2e0;
}

.consent-copy {
  min-width: 0;
  flex: 1;
  color: #3f5157;
  font-size: 24rpx;
  line-height: 1.55;
}

.consent-state {
  flex-shrink: 0;
  color: #52656a;
  font-size: 23rpx;
}

.booking-bottom {
  padding: 14rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top-color: #d9e2e0;
  background: rgba(255, 255, 255, 0.98);
}

.submit-hint {
  justify-content: center;
  gap: 8rpx;
  min-height: 36rpx;
  margin-bottom: 8rpx;
  color: #748388;
  font-size: 22rpx;
}

.submit-hint.ready {
  color: #167a6e;
}

.booking-bottom .primary-button {
  width: 100% !important;
  margin-right: 0 !important;
  margin-left: 0 !important;
  border-radius: 8rpx;
  background: #167a6e;
}

.booking-bottom .primary-button[disabled] {
  color: #7f8e8b;
  background: #dfe8e6;
}

@media (max-width: 360px) {
  .issue-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
