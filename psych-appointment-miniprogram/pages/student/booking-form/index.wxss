.summary-panel {
  padding: 26rpx;
  background: #eef7f5;
  border-color: #c9e6df;
}

.summary-label {
  color: #216b62;
  font-size: 23rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.choice-row {
  display: flex;
  gap: 36rpx;
}

.choice {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  color: #344054;
  font-size: 26rpx;
}

.choice-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip-choice {
  min-height: 58rpx;
  padding: 10rpx 14rpx 10rpx 6rpx;
  border-radius: 10rpx;
  background: #f6f7f9;
}

.picker-text {
  display: flex;
  align-items: center;
}

.risk-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.risk-item {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.5;
}

.risk-desc {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.risk-warning {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  color: #b54708;
  background: #fff7e6;
  font-size: 24rpx;
  line-height: 1.55;
}

.consent-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.6;
}

.consent-copy {
  flex: 1;
}
