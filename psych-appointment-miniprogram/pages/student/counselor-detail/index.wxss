page {
  background: #f7faf9;
  background-image: none;
}

.detail-page {
  min-height: 100vh;
  padding-top: 18rpx;
  background: #f7faf9;
  color: #15262b;
}

.detail-loading,
.empty-state {
  padding: 80rpx 30rpx;
  text-align: center;
}

.loading-title,
.empty-title {
  color: #26393e;
  font-size: 28rpx;
  font-weight: 700;
}

.loading-text,
.empty-text {
  margin-top: 10rpx;
  color: #748388;
  font-size: 23rpx;
  line-height: 1.5;
}

.profile-band {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 230rpx;
  margin: 0 -28rpx;
  padding: 30rpx 36rpx;
  border-top: 1rpx solid #d7e5e2;
  border-bottom: 1rpx solid #d7e5e2;
  background: #eef7f5;
  overflow: hidden;
}

.profile-band-lines {
  position: absolute;
  right: -28rpx;
  bottom: -20rpx;
  width: 360rpx;
  height: 150rpx;
  opacity: 0.34;
  pointer-events: none;
}

.detail-avatar {
  position: relative;
  z-index: 1;
  display: block;
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
  border: 2rpx solid #b7d1cb;
  border-radius: 50%;
  background: #ffffff;
}

.detail-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #167a6e;
  font-size: 38rpx;
  font-weight: 800;
}

.identity-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
  flex: 1;
}

.identity-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.identity-name {
  color: #15262b;
  font-size: 40rpx;
  font-weight: 800;
}

.verified-badge {
  padding: 5rpx 10rpx;
  border: 1rpx solid #9fc8bf;
  border-radius: 4rpx;
  color: #4d8067;
  background: #f7fbfa;
  font-size: 22rpx;
  font-weight: 700;
}

.identity-title,
.identity-campus {
  margin-top: 10rpx;
  color: #52656a;
  font-size: 25rpx;
  line-height: 1.4;
}

.profile-section {
  padding: 28rpx 2rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.section-label {
  color: #167a6e;
  font-size: 27rpx;
  font-weight: 700;
}

.expertise-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.expertise-tag {
  padding: 8rpx 13rpx;
  border-radius: 4rpx;
  color: #52656a;
  background: #f0f3f2;
  font-size: 23rpx;
}

.profile-text {
  margin-top: 12rpx;
  color: #3f5157;
  font-size: 25rpx;
  line-height: 1.7;
}

.training-text {
  color: #66777b;
}

.profile-text-clamped {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.intro-toggle {
  display: inline-flex;
  align-items: center;
  min-height: 60rpx;
  margin-top: 10rpx;
  color: #3478e5;
  font-size: 24rpx;
  font-weight: 650;
}

.date-section,
.slot-section {
  margin-top: 30rpx;
}

.section-heading,
.slot-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  color: #15262b;
  font-size: 31rpx;
  font-weight: 800;
}

.section-note,
.section-link,
.slot-count {
  color: #748388;
  font-size: 23rpx;
  line-height: 1.45;
}

.section-note {
  margin-top: 5rpx;
}

.section-link {
  min-height: 52rpx;
  padding: 10rpx 0 0 20rpx;
  color: #52656a;
}

.week-scroll {
  margin-top: 16rpx;
  white-space: nowrap;
}

.week-row {
  display: inline-flex;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  background: #ffffff;
}

.date-cell {
  width: 124rpx;
  min-height: 142rpx;
  flex-shrink: 0;
  padding: 18rpx 8rpx 14rpx;
  border-right: 1rpx solid #e2e9e7;
  text-align: center;
}

.date-cell:last-child {
  border-right: 0;
}

.date-cell.active {
  color: #167a6e;
  background: #eaf5f3;
  box-shadow: inset 0 -4rpx 0 #167a6e;
}

.date-cell.disabled {
  color: #9ba7a5;
}

.date-weekday {
  font-size: 23rpx;
  font-weight: 700;
}

.date-value {
  margin-top: 10rpx;
  font-size: 25rpx;
}

.date-count {
  min-height: 32rpx;
  margin-top: 8rpx;
  color: #748388;
  font-size: 21rpx;
}

.slot-heading {
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.selection-note {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-left: 4rpx solid #167a6e;
  border-radius: 0 8rpx 8rpx 0;
  color: #3f635b;
  background: #eaf5f3;
  font-size: 23rpx;
  line-height: 1.45;
}

.slot-groups {
  display: grid;
  gap: 28rpx;
  margin-top: 24rpx;
}

.date-title {
  padding-left: 14rpx;
  border-left: 4rpx solid #167a6e;
  color: #26393e;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 1.35;
}

.slot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.slot-card {
  min-height: 154rpx;
  padding: 20rpx;
  border: 1rpx solid #d9e2e0;
  border-radius: 8rpx;
  background: #ffffff;
}

.slot-card.selected {
  border-color: #3478e5;
  background: #eef5ff;
  box-shadow: inset 0 0 0 1rpx #3478e5;
}

.slot-time {
  color: #15262b;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 1.4;
}

.selected-mark {
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  color: #ffffff;
  background: #3478e5;
  font-size: 20rpx;
  font-weight: 700;
}

.slot-place {
  margin-top: 9rpx;
  color: #52656a;
  font-size: 23rpx;
  line-height: 1.4;
}

.slot-mode {
  margin-top: 9rpx;
  color: #748388;
  font-size: 22rpx;
  line-height: 1.4;
}

.empty-state {
  padding: 58rpx 20rpx;
}

.empty-action {
  width: 260rpx;
  min-height: 76rpx;
  margin: 22rpx auto 0;
  border: 1rpx solid #9fc8bf;
  border-radius: 8rpx;
  color: #167a6e;
  background: #eaf5f3;
  font-size: 24rpx;
}

.empty-action::after {
  border: 0;
}

.bottom-action {
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #d9e2e0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(21, 38, 43, 0.04);
}

.primary-button {
  min-height: 96rpx;
  border-radius: 8rpx;
  background: #167a6e;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-button[disabled] {
  color: #7f8e8b;
  background: #dfe8e6;
}
