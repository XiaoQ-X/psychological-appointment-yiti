page {
  min-height: 100%;
  background: #f7faf9;
}

.password-page {
  min-height: 100vh;
  padding: 20rpx 32rpx 48rpx;
  color: #15262b;
  background: #f7faf9;
}

.brand-bar,
.brand-lockup,
.field-head {
  display: flex;
  align-items: center;
}

.brand-bar {
  justify-content: space-between;
  gap: 18rpx;
  min-height: 66rpx;
  border-bottom: 4rpx solid #167a6e;
}

.brand-lockup {
  min-width: 0;
}

.brand-name {
  flex-shrink: 0;
  color: #15262b;
  font-size: 34rpx;
  font-weight: 800;
}

.brand-divider {
  width: 1rpx;
  height: 30rpx;
  margin: 0 16rpx;
  background: #b8c5c2;
}

.brand-product,
.role-mark {
  color: #52656a;
  font-size: 23rpx;
}

.role-mark {
  flex-shrink: 0;
  padding: 6rpx 10rpx;
  border: 1rpx solid #9fc8bf;
  border-radius: 4rpx;
  color: #4d8067;
  font-weight: 700;
}

.security-intro {
  position: relative;
  min-height: 238rpx;
  overflow: hidden;
  padding: 38rpx 0 30rpx;
  border-bottom: 1rpx solid #d9e2e0;
}

.intro-kicker {
  color: #167a6e;
  font-size: 22rpx;
  font-weight: 700;
}

.intro-title {
  margin-top: 10rpx;
  color: #15262b;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.intro-copy {
  position: relative;
  z-index: 1;
  width: 72%;
  margin-top: 14rpx;
  color: #52656a;
  font-size: 24rpx;
  line-height: 1.55;
}

.intro-art {
  position: absolute;
  right: -52rpx;
  bottom: -18rpx;
  width: 420rpx;
  height: 142rpx;
  opacity: 0.28;
}

.password-form {
  padding-top: 30rpx;
}

.field + .field {
  margin-top: 24rpx;
}

.field-head {
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.field-label {
  color: #26393e;
  font-size: 25rpx;
  font-weight: 700;
}

.visibility {
  min-height: 50rpx;
  padding: 8rpx 0 8rpx 24rpx;
  color: #167a6e;
  font-size: 23rpx;
  font-weight: 700;
}

.password-input {
  width: 100%;
  height: 90rpx;
  padding: 0 20rpx;
  border: 1rpx solid #c9d8d5;
  border-radius: 8rpx;
  color: #15262b;
  background: #ffffff;
  font-size: 27rpx;
}

.password-input.input-error {
  border-color: #d95c4f;
}

.field-error {
  display: block;
  margin-top: 8rpx;
  color: #b64236;
  font-size: 22rpx;
}

.security-note {
  margin-top: 26rpx;
  padding: 18rpx 20rpx;
  border-left: 5rpx solid #167a6e;
  background: #eaf4f1;
}

.note-title {
  color: #245b54;
  font-size: 24rpx;
  font-weight: 800;
}

.note-row {
  margin-top: 6rpx;
  color: #52656a;
  font-size: 23rpx;
  line-height: 1.55;
}

.submit-button,
.switch-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100% !important;
  min-height: 92rpx;
  margin-right: 0 !important;
  margin-left: 0 !important;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.submit-button {
  margin-top: 30rpx;
  color: #ffffff;
  background: #167a6e;
}

.submit-button.disabled {
  color: #7f8e8b;
  background: #dfe8e6;
}

.switch-button {
  margin-top: 14rpx;
  border: 1rpx solid #c9d8d5;
  color: #3f5157;
  background: #ffffff;
}

.submit-button::after,
.switch-button::after {
  border: 0;
}

.support-note {
  margin-top: 26rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #d9e2e0;
  color: #748388;
  font-size: 22rpx;
  line-height: 1.55;
  text-align: center;
}
