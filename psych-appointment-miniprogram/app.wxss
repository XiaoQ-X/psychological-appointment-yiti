page {
  min-height: 100%;
  background: #f6f7f9;
  color: #17202a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.page.with-bottom-action {
  padding-bottom: 148rpx;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 750;
  color: #101828;
  margin: 8rpx 0 10rpx;
}

.page-subtitle {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.page-head {
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.section {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 750;
}

.section-note {
  color: #667085;
  font-size: 23rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e6e9ef;
  border-radius: 16rpx;
  padding: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.muted {
  color: #667085;
}

.strong {
  color: #101828;
  font-weight: 750;
}

.tiny {
  font-size: 24rpx;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  color: #344054;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #d7dde8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #17202a;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
  line-height: 1.5;
}

.primary-button,
.secondary-button,
.danger-button {
  width: 100%;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 650;
  margin: 0;
}

.primary-button {
  color: #ffffff;
  background: #216b62;
}

.secondary-button {
  color: #216b62;
  background: #eef7f5;
}

.danger-button {
  color: #b42318;
  background: #fff1f0;
}

.ghost-button {
  width: auto;
  min-height: 56rpx;
  padding: 0 20rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #475467;
  background: #ffffff;
  border: 1rpx solid #e6e9ef;
  font-size: 24rpx;
}

.button-stack {
  display: grid;
  gap: 18rpx;
  margin-top: 28rpx;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #edf0f5;
  z-index: 10;
}

.card-list {
  display: grid;
  gap: 18rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e6e9ef;
  border-radius: 16rpx;
  padding: 24rpx;
}

.card-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 700;
}

.card-meta {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.info-row {
  min-height: 58rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.5;
}

.info-row text:first-child {
  color: #667085;
  flex-shrink: 0;
}

.info-row text:last-child {
  text-align: right;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #216b62;
  background: #eef7f5;
  font-size: 22rpx;
  font-weight: 650;
}

.tag.warning {
  color: #b54708;
  background: #fff7e6;
}

.tag.danger {
  color: #b42318;
  background: #fff1f0;
}

.tag.neutral {
  color: #475467;
  background: #f2f4f7;
}

.chip,
.filter-chip {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #475467;
  background: #ffffff;
  border: 1rpx solid #e6e9ef;
  font-size: 23rpx;
}

.chip.active,
.filter-chip.active {
  color: #216b62;
  background: #eef7f5;
  border-color: #99c9c1;
  font-weight: 700;
}

.inline-link {
  color: #216b62;
  font-size: 25rpx;
  font-weight: 650;
}

.empty {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #667085;
  line-height: 1.6;
}

.divider {
  height: 1rpx;
  background: #edf0f5;
  margin: 22rpx 0;
}

.status-panel {
  background: #eef7f5;
  border: 1rpx solid #c9e6df;
}

.status-panel.warning {
  background: #fff7e6;
  border-color: #f6d7a9;
}

.status-title {
  color: #216b62;
  font-size: 34rpx;
  font-weight: 800;
}

.status-panel.warning .status-title {
  color: #b54708;
}

.safe-area-spacer {
  height: env(safe-area-inset-bottom);
}
